---
import MainLayout from '../layouts/MainLayout.astro';

const faqs = [
    {
        question: "How far in advance should we book?",
        answer: "For weddings, I typically recommend booking 12-18 months in advance to ensure availability. For lifestyle or family sessions, 2-3 months is usually sufficient."
    },
    {
        question: "Do you travel for shoots?",
        answer: "Yes, absolutely! I love exploring new locations. While I am based in South Africa, I am available for travel both locally and internationally. Travel fees may apply depending on the destination."
    },
    {
        question: "When will we receive our photos?",
        answer: "For weddings, you can expect a 'sneak peek' within 48 hours. The full gallery is typically delivered within 6-8 weeks. For smaller sessions, the delivery time is usually 2-3 weeks."
    },
    {
        question: "How many photos will we receive?",
        answer: "Every shoot is unique, but on average, a full wedding day results in 400-600 edited images. A lifestyle session typically results in 40-60 edited images."
    },
    {
        question: "Do you offer wedding albums?",
        answer: "Yes, I offer high-quality, custom-designed heirloom albums. These can be added to any package or ordered after your gallery has been delivered."
    }
];
---

<MainLayout title="FAQ | ankesefotos">
    <header class="contact-hero-scaffold">
    </header>

    <main class="py-5 mt-5">
        <div class="container py-lg-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="faq-header text-center mb-5">
                        <h1 class="font-serif display-4 mb-3">frequently asked questions</h1>
                        <p class="lead font-serif opacity-75">Everything you need to know before we start.</p>
                    </div>

                    <div class="faq-list">
                        {faqs.map((faq, index) => (
                            <div class={`faq-item ${index !== faqs.length - 1 ? 'border-bottom' : ''} py-4`}>
                                <h3 class="font-serif h4 mb-3">{faq.question}</h3>
                                <p class="font-serif opacity-75 small mb-0">{faq.answer}</p>
                            </div>
                        ))}
                    </div>

                    <div class="faq-footer text-center mt-5 pt-5">
                        <p class="font-serif opacity-75">
                            Still have questions? Feel free to send me a mail at <br>
                            <a href="mailto:anckevdschyff12@gmail.com" class="text-dark fw-bold text-decoration-none">anckevdschyff12@gmail.com</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</MainLayout>

<style>
    .faq-item {
        border-color: rgba(44, 37, 32, 0.1) !important;
    }
</style>
