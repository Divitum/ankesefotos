---
import '../styles/bootstrap/bootstrap.min.css';
import '../styles/style.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

		<!-- Google Fonts: Spectral, Tangerine -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,200;1,300;1,400;1,500;1,600;1,700;1,800&family=Tangerine:wght@400;700&display=swap" rel="stylesheet" />
		
		<!-- Bootstrap Icons -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
	</head>
	<body style="background-color: var(--color-bg);">
		<Navbar />
		<slot />
		<Footer />

		<!-- Bootstrap Bundle JS -->
		<script src="../scripts/bootstrap/bootstrap.bundle.min.js"></script>
	</body>
</html>
