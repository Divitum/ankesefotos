---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
    href: string;
}

const { href, ...props } = Astro.props;

// import.meta.env.BASE_URL usually ends with a slash if defined.
// We strip the trailing slash from base and ensure href starts with a slash for a clean join.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const normalizedHref = href;
---
<a href={normalizedHref} {...props}><slot /></a>
