---
import Link from './Link.astro';
---
<footer class="footer-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <!-- Branding & Socials -->
            <div class="col-md-4 text-center text-md-start mb-4 mb-md-0">
                <h3 class="brand-font footer-brand mb-3">anke.se.fotos</h3>
                <div class="social-links">
                    <a href="https://www.instagram.com/anke.se.fotos/" target="_blank" class="me-3 text-decoration-none text-dark"><i class="bi bi-instagram fs-4"></i></a>
                    <a href="mailto:anckevdschyff12@gmail.com" class="text-decoration-none text-dark"><i class="bi bi-envelope fs-4"></i></a>
                </div>
            </div>
            <!-- Navigation -->
            <div class="col-md-4 text-center mb-4 mb-md-0">
                <div class="footer-nav">
                    <Link href="/" class="footer-link mx-2">home</Link>
                    <Link href="/portfolio" class="footer-link mx-2">Portfolio</Link>
                    <Link href="/faq" class="footer-link mx-2">FAQ</Link>
                    <Link href="/about" class="footer-link mx-2">About me</Link>
                    <Link href="/contact" class="footer-link mx-2">Contact</Link>
                </div>
            </div>
            <!-- Copyright -->
            <div class="col-md-4 text-center text-md-end">
                <p class="copyright-text mb-0">&copy; All content copyright of anke.se.fotos Photography {new Date().getFullYear()}</p>
            </div>
        </div>
    </div>
</footer>
